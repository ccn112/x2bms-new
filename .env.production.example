# =========================================================================
# X2-BMS — Production env (scale). Copy relevant blocks into the real .env on
# production. LOCAL/DEV keeps the database drivers below commented / as-is.
# See x2/docs/guide/scale-ops.md and x2/docs/ARCHITECTURE_X2_PLATFORM_V1.md §13b.
# =========================================================================

APP_ENV=production
APP_DEBUG=false

# --- Redis (bật trên production; local chưa cài Redis thì GIỮ database) -----
REDIS_CLIENT=phpredis
REDIS_HOST=your-redis-host
REDIS_PASSWORD=your-redis-password
REDIS_PORT=6379

# Chuyển cache/queue/session sang Redis ở production.
CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis

# --- Read/write DB split (replica) ----------------------------------------
# DB_HOST vẫn là primary (ghi). Thêm 1+ host replica (phân tách bằng dấu phẩy) để dồn đọc.
# Bỏ trống DB_READ_HOST => đọc & ghi cùng primary (an toàn khi chưa có replica).
DB_HOST=your-primary-host
# DB_READ_HOST=replica-1-host,replica-2-host
# DB_WRITE_HOST=your-primary-host

# --- Octane (FrankenPHP) ---------------------------------------------------
OCTANE_SERVER=frankenphp
OCTANE_HTTPS=true

# --- Horizon ---------------------------------------------------------------
# Horizon dùng kết nối Redis cho queue. Cấu hình pool trong config/horizon.php.

# --- Broadcast (nếu dùng realtime) ----------------------------------------
# BROADCAST_CONNECTION=reverb
